deepseek.base-url=https://api.deepseek.com
deepseek.model=deepseek-v4-pro
deepseek.api-key=replace-with-your-deepseek-api-key

spring.rabbitmq.host=10.119.6.66
spring.rabbitmq.port=5672
spring.rabbitmq.username=replace-with-rabbitmq-username
spring.rabbitmq.password=replace-with-rabbitmq-password
spring.rabbitmq.listener.simple.missing-queues-fatal=false

spring.data.redis.host=10.119.6.66
spring.data.redis.port=6379
spring.data.redis.password=replace-with-redis-password
spring.data.redis.database=0
spring.data.redis.timeout=3000ms

elasticsearch.enabled=true
elasticsearch.url=http://10.119.6.66:9200
elasticsearch.username=
elasticsearch.password=
